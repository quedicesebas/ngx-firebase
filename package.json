{
  "name": "ngx-firebase",
  "version": "0.0.0",
  "workspaces": [
    "projects/ngx-firebase"
  ],
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build && node -e \"const fs = require('fs'); ['README.md', 'LICENSE'].forEach(f => { if (fs.existsSync(f)) fs.copyFileSync(f, 'dist/ngx-firebase/' + f); })\"",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "release": "npm version --no-git-tag-version -w ngx-firebase"
  },
  "private": true,
  "packageManager": "npm@11.1.0",
  "dependencies": {
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/router": "^22.0.0",
    "firebase": "^12.16.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.7",
    "@angular/cli": "^22.0.6",
    "@angular/compiler-cli": "^22.0.0",
    "jsdom": "^28.0.0",
    "ng-packagr": "^22.0.0",
    "prettier": "^3.8.1",
    "typescript": "~6.0.2",
    "vitest": "^4.0.8"
  }
}